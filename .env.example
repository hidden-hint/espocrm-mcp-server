# Target EspoCRM instance (required)
ESPOCRM_BASE_URL=https://crm.example.com

# Auth mode:
#   apiKey      - single shared API key from ESPOCRM_API_KEY (single-user / stdio)
#   passthrough - forward each caller's credential from request headers (per-user ACL; http only)
ESPOCRM_AUTH_MODE=apiKey

# Required when ESPOCRM_AUTH_MODE=apiKey
ESPOCRM_API_KEY=

# In passthrough mode, how to interpret a bare `Authorization: Bearer <x>` header:
#   apiKey            - forward as X-Api-Key
#   espoAuthorization - forward as Espo-Authorization
MCP_PASSTHROUGH_AS=apiKey

# Transport: stdio (local) | http (remote / Docker)
MCP_TRANSPORT=stdio

# http transport settings
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp

# Write tools (create/update/delete/post_to_stream) are only registered when this is false.
# Writes are still ACL-checked per user; this is a hard global off-switch on top of that.
MCP_READ_ONLY=true

# Entity types to expose as dedicated tools (search_<entity>, get_<entity>).
# Comma-separated. Keep this curated — a tool per entity per operation multiplies fast.
MCP_ENTITY_TYPES=Lead,Contact,Account,Opportunity

# Metadata cache lifetime in seconds
ESPOCRM_METADATA_TTL=300
