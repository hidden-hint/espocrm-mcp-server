# Target EspoCRM instance (required)
ESPOCRM_BASE_URL=https://crm.example.com

# Auth mode:
#   apiKey - single shared API key from ESPOCRM_API_KEY (single-user / stdio)
#   oauth  - OAuth 2.1: each user logs in with their EspoCRM username/password and
#            the server issues per-user tokens (per-user ACL; http only)
ESPOCRM_AUTH_MODE=apiKey

# Required when ESPOCRM_AUTH_MODE=apiKey
ESPOCRM_API_KEY=

# Required when ESPOCRM_AUTH_MODE=oauth: the public HTTPS URL this server is reached
# at. It is the OAuth issuer and the resource identifier tokens are bound to.
MCP_OAUTH_ISSUER_URL=https://mcp.crm.example.com

# Required when ESPOCRM_AUTH_MODE=oauth: 32-byte key that encrypts the access and
# refresh tokens (which carry the caller's EspoCRM credential). Generate with:
#   openssl rand -base64 32
# Rotating it invalidates every issued token; keep it secret and stable.
MCP_OAUTH_ENCRYPTION_KEY=

# Access-token lifetime in seconds (oauth mode). Refresh tokens renew silently.
MCP_ACCESS_TOKEN_TTL=3600

# Transport: stdio (local) | http (remote / Docker). oauth mode requires http.
MCP_TRANSPORT=stdio

# http transport settings
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp

# Write tools (create/update/delete/post_to_stream) are only registered when this is false.
# Writes are still ACL-checked per user; this is a hard global off-switch on top of that.
MCP_READ_ONLY=true

# Entity types to expose as dedicated tools (search_<entity>, get_<entity>).
# Comma-separated. Keep this curated — a tool per entity per operation multiplies fast.
MCP_ENTITY_TYPES=Lead,Contact,Account,Opportunity

# Metadata cache lifetime in seconds
ESPOCRM_METADATA_TTL=300
