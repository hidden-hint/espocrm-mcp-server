{
  "name": "@espocrm/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for EspoCRM — exposes any EspoCRM instance to MCP clients over its public REST API.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "espocrm-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3"
  }
}
